# Example for plane-app/plane.env (the real file is generated by setup.sh and gitignored).
# After `./setup.sh install`, edit plane-app/plane.env — the vars you usually change are
# marked CHANGE below. Secrets are blanked here; set strong values before any real use.

# --- Network / access (CHANGE) ---
APP_DOMAIN=localhost
APP_RELEASE=v1.3.1
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443
WEB_URL=http://${APP_DOMAIN}
DEBUG=0
CORS_ALLOWED_ORIGINS=http://localhost
API_BASE_URL=http://api:8000

# --- Replicas ---
WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1
WORKER_REPLICAS=1
BEAT_WORKER_REPLICAS=1
LIVE_REPLICAS=1

# --- Postgres (CHANGE password) ---
PGHOST=plane-db
PGDATABASE=plane
POSTGRES_USER=plane
POSTGRES_PASSWORD=change-me
POSTGRES_DB=plane
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data
DATABASE_URL=

# --- Redis ---
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=

# --- RabbitMQ (CHANGE password) ---
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=plane
AMQP_URL=

# --- TLS / proxy ---
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TRUSTED_PROXIES=0.0.0.0/0
SITE_ADDRESS=:80
CERT_EMAIL=
CERT_ACME_DNS=

# --- Secrets (SET strong unique values; never commit real ones) ---
SECRET_KEY=
LIVE_SERVER_SECRET_KEY=

# --- Object storage / MinIO (CHANGE keys) ---
USE_MINIO=1
AWS_REGION=
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
FILE_SIZE_LIMIT=5242880
MINIO_ENDPOINT_SSL=0

# --- Misc ---
GUNICORN_WORKERS=1
API_KEY_RATE_LIMIT=60/minute
WEBHOOK_ALLOWED_IPS=
WEBHOOK_ALLOWED_HOSTS=
DOCKERHUB_USER=makeplane
PULL_POLICY=if_not_present
CUSTOM_BUILD=false
# UNCOMMENT if on arm64 and no arm64 image for APP_RELEASE:
# DOCKER_PLATFORM=linux/amd64
