plane-selfhost/plane-app/plane.env
plane-selfhost/plane-app/plane.env.*
plane-selfhost/plane-app/archive/
plane-selfhost/plane-app/backup/
plane-selfhost/*.log

# MCP server local config (use .env.example as template)
plane-mcp/.env

# General
*.log
.DS_Store
