# Copy to .env and adjust. See README.md / AGENTS.md.

# Plane API base URL as seen FROM the MCP container.
# Default uses the Plane stack's internal docker network (service "proxy").
# Alternatives: http://host.docker.internal  |  http://<host-lan-ip>
PLANE_BASE_URL=http://proxy

# Host port to publish the MCP HTTP server on.
MCP_PORT=8211

# Required only so HTTP mode boots; the api-key endpoint ignores these. Leave as-is.
PLANE_OAUTH_PROVIDER_CLIENT_ID=dummy
PLANE_OAUTH_PROVIDER_CLIENT_SECRET=dummy
PLANE_OAUTH_PROVIDER_BASE_URL=http://localhost:8211
